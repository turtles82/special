{
  "mirrors": [
    {
      "url": "https://edpuzzle.hgci.org",
      "priority": 1,
      "name": "Primary Mirror"
    },
    {
      "url": "https://edpuzzle-backup.example.com",
      "priority": 2,
      "name": "Backup Mirror"
    },
    {
      "url": "https://edpuzzle-alt.example.com",
